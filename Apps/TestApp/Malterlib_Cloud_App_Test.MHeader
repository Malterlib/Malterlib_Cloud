%Target "Malterlib_Cloud_Test"
{
	Property
	{
		MalterlibPostCopyProject "Malterlib_Cloud_Test"
		{
			!!MalterlibPostCopyProject ""
		}
		MalterlibPostCopyDestination "TestApp/"
		MalterlibLinkWithOpenSSL true
		MalterlibConcurrency_DistributedActors true
	}
	Target
	{
		DebuggerCommandArguments "--daemon-run-debug"
		BaseFileName "TestApp"
	}
	%Group Source
	{
		%File "Source/*"
	}
	%Dependency "Lib_Malterlib_Cloud"
	%Dependency "Lib_Malterlib"
}

Property.Malterlib_Cloud_App_Targets "Malterlib_Cloud_Test;@(Malterlib_Cloud_App_Targets)"
