%Target "Lib_Malterlib_Cloud_Test"
{
	Property
	{
	}
	Target
	{
		Type "StaticLibrary"
		BaseName "Malterlib_Cloud_Test"
		Group "Apps"
	}
	%Group "Source"
	{
		%File "Source/Malterlib_Cloud_App_*"
	}

	%Dependency "Lib_Malterlib_Cloud"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib"
	{
		Dependency.Indirect true
	}
}

%Target "Malterlib_Cloud_Test"
{
	Property
	{
		ProductName "Malterlib Cloud Test App"
		MalterlibTestApp true
		MalterlibPostCopyProject "Malterlib_Cloud_Test"
		{
			!!MalterlibPostCopyProject undefined
		}
		MalterlibPostCopyDestination "TestApp"
		{
			!!MalterlibPostCopyDestination undefined
		}
		MalterlibTargetNameType "Normal"
	}
	Target
	{
		DebuggerCommandArguments ["--daemon-run-debug"]
		BaseFileName "TestApp"
		Group "Apps"
	}
	%Group "Source"
	{
		%File "Source/Malterlib_Cloud_AppLocal_*"
	}
	%Dependency "Lib_Malterlib_Cloud_Test"
}

Property
{
	Malterlib_App_Enable_Test: bool = true

	Malterlib_Cloud_App_Targets =+ "Malterlib_Cloud_Test"
	{
		!!Malterlib_App_Enable_Test true
	}
}
