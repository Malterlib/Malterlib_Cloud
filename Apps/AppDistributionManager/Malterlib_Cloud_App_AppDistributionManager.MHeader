%Target "Lib_Malterlib_Cloud_AppDistributionManager"
{
	Property
	{
	}
	Target
	{
		Type "StaticLibrary"
		BaseName "Malterlib_Cloud_AppDistributionManager"
		Group "Apps"
	}
	%Group "Source"
	{
		%File "Source/Malterlib_Cloud_App_*"
	}

	%Dependency "Lib_Malterlib_Cloud"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib"
	{
		Dependency.Indirect true
	}
}

%Target "Malterlib_Cloud_AppDistributionManager"
{
	Property
	{
		ProductName "Malterlib Cloud App Distribution Manager"
		MalterlibTestApp true
		MalterlibPostCopyProject "Malterlib_Cloud_AppDistributionManager"
		{
			!!MalterlibPostCopyProject undefined
		}
		MalterlibTargetNameType "Normal"
		MalterlibCloudVersionInfo_RunAsUser "MalterlibCloudAppDistManager"
		MalterlibCloudVersionInfo_RunAsGroup "MalterlibCloudAppDistManager"
		MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: "Distribution/^*.json"}
	}
	Target
	{
		DebuggerCommandArguments ["--daemon-run-debug"]
		BaseFileName "AppDistributionManager"
		Group "Apps"
	}
	%Group "Source"
	{
		%File "Source/Malterlib_Cloud_AppLocal_*"
	}
	%Dependency "Lib_Malterlib_Cloud_AppDistributionManager"
}

Property
{
	Malterlib_App_Enable_AppDistributionManager: bool = true

	Malterlib_Cloud_App_Targets =+ "Malterlib_Cloud_AppDistributionManager"
	{
		!!Malterlib_App_Enable_AppDistributionManager true
	}
}
