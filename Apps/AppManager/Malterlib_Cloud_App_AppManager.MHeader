%Target "Malterlib_Cloud_AppManager"
{
	Property
	{
		MalterlibPostCopyProject "Malterlib_Cloud_AppManager"
		{
			!!MalterlibPostCopyProject ""
		}
		MalterlibLinkWithOpenSSL true
		MalterlibConcurrency_DistributedActors true
	}
	Target
	{
		DebuggerCommandArguments "-RunAsProgram"
		BaseFileName "AppManager"
	}
	%Group Source
	{
		%File "Source/*"
	}
	%Dependency "Lib_Malterlib_Cloud"
	%Dependency "Lib_Malterlib"
}

Property.Malterlib_Cloud_App_Targets "Malterlib_Cloud_AppManager;@(Malterlib_Cloud_App_Targets)"
