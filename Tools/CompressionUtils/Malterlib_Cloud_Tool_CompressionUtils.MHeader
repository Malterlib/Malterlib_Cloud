%Repository "libarchive"
{
	Repository
	{
		Type "External"
		Remotes =+ {Name: "upstream", URL: "https://github.com/libarchive/libarchive.git"}
	}
}

%Import "../../../../External/libarchive/CMakeLists.txt"
{
	Property.MalterlibLinkWithBoringSSL true

	Property
	{
		!!PlatformFamily "Windows"

		MalterlibWindowsNtVersion "_WIN32_WINNT_WIN7"
		MalterlibWindowsVersion "NTDDI_WIN7"
	}

	Import.CMake_FullRebuildVersion `@(Import.CMake_FullRebuildVersion).1`
	Import.CMake_Variables =+ [
		"ENABLE_TAR=1"
		, "ENABLE_TAR_SHARED=0"
		, "ENABLE_CPIO=0"
		, "ENABLE_CAT=0"
		, "ENABLE_CAT_SHARED=0"
		, "ENABLE_TEST=0"
		, "ENABLE_COVERAGE=0"
		, "ENABLE_INSTALL=0"
		, "ENABLE_ICONV=0"
		, "ENABLE_LZ4=0"
		, "ENABLE_ZSTD=0"
		, "ENABLE_OPENSSL=1"
		, "ENABLE_NETTLE=0"
		, "ENABLE_LIBXML2=0"
		, "ENABLE_LZMA=0"
		, "ENABLE_BZip2=0"
		, "ENABLE_EXPAT=0"
		, `OPENSSL_ROOT_DIR=@("../../../../External/boringssl"->MakeAbsolute())`
		, "OPENSSL_LIBRARIES=/dev/null"
		, "OPENSSL_CRYPTO_LIBRARY=/dev/null"
		, "OPENSSL_SSL_LIBRARY=/dev/null"
	]

	Import.CMake_Variables =+ [
		"HAVE_ZLIB_H=1"
		, "ARCHIVE_CRYPTO_MD5_OPENSSL=1"
		, "ARCHIVE_CRYPTO_RMD160_OPENSSL=1"
		, "ARCHIVE_CRYPTO_SHA1_OPENSSL=1"
		, "ARCHIVE_CRYPTO_SHA256_OPENSSL=1"
		, "ARCHIVE_CRYPTO_SHA384_OPENSSL=1"
		, "ARCHIVE_CRYPTO_SHA512_OPENSSL=1"
	]

	Import.CMake_Variables =+ "HAVE_LZMA_STREAM_ENCODER_MT=0"
	{
		!!PlatformFamily "OSX"
	}

	Import.CMake_Variables =+ "CMAKE_BUILD_WITH_INSTALL_RPATH=ON"
	{
		&
		{
			PlatformFamily "Linux"
			!HostPlatformFamily "Linux"
		}
	}

	Compile
	{
		!!MalterlibCompileSupportTabSetings true
		IndentWidth 4
		TabWidth 4
		UsesTabs true
	}
	Compile
	{
		!!CompileDialect "C"
		PrefixHeader undefined
		Warnings "Off"
		{
			!!PlatformFamily "Windows"
		}
	}

	%Target "Com_libarchive_bsdtar"
	{
		Property.ProductName "BSD Tar"
		Target
		{
			LinkWithLibraries += "-lacl"
			{
				!!PlatformFamily "Linux"
			}
		}
		%Group "Source"
		{
			%File "Source/AllowInvalidExit.cpp"
			{
				!!PlatformFamily "Windows"
			}
		}
		%Dependency "Lib_Malterlib"
		%Dependency "Lib_zlib"
	}
}
