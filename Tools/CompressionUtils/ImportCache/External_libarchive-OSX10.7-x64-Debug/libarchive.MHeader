%Target "Com_libarchive_bsdtar"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../../../External/libarchive'->MakeAbsolute())/libarchive`->MakeAbsolute(),
			`@('.'->MakeAbsolute())`->MakeAbsolute(),
			`@('../../../../../..'->MakeAbsolute())/External/boringssl/include`->MakeAbsolute(),
			`@('../../../../../../External/libarchive'->MakeAbsolute())/libarchive_fe`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_CONFIG_H",
			"LIBARCHIVE_STATIC"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/libarchive"
	{
		!!Target.Group undefined
	}
	Target.Type "ConsoleExecutable"
	Target.BaseName "libarchive_bsdtar"
	Target.BaseFileName "bsdtar"
	%Group "tar"
	{
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/bsdtar.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/bsdtar.h`
		{
			Compile.Disabled true
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/bsdtar_platform.h`
		{
			Compile.Disabled true
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/cmdline.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/creation_set.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/read.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/subst.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/util.c`
		{
			Compile.Type "C"
		}
		%File `@('../../../../../../External/libarchive'->MakeAbsolute())/tar/write.c`
		{
			Compile.Type "C"
		}
	}
	%Group "libarchive_fe"
