Property.CMakeOutputPath_libarchive define string = `@('.'->MakeAbsolute())`->MakeAbsolute()
%Target "Tool_libarchive_Nightly"
{
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Compile.Disabled true
	Target.Group "External/libarchive"
	{
		!!Target.Group undefined
	}
	Target.Type "Tool"
	Target.BaseName "libarchive_Nightly"
	Target.BaseFileName "Nightly"
	%Group "OSX10.7"
	{
		%Group "x64"
		{
			%Group `@(FullConfiguration)`
			{
				%Group "CMakeFiles"
				{
					%File `@('.'->MakeAbsolute())/CMakeFiles/Nightly.rule`
					{
						Compile
						{
							Custom_CommandLine `@(`@('../../../../../..'->MakeAbsolute())/Binaries/Malterlib/OSX/x64/ctest`->MakeAbsolute()->EscapeHost()) -D Nightly`
							AllowNonExisting true
							Disabled false
							Custom_WorkingDirectory `@('.'->MakeAbsolute())`->MakeAbsolute()
							Custom_Outputs []
							Custom_Inputs []
						}
					}
				}
			}
		}
	}
}
