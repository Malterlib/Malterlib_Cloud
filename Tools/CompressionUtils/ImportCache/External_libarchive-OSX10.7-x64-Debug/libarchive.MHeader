%Target "Dll_libarchive_archive"
{
	Compile
	{
		!!Compile.Type "C"
		SearchPath += [
			`@('../../../../../../External/libarchive'->MakeAbsolute())/libarchive`->MakeAbsolute(),
			`@('.'->MakeAbsolute())`->MakeAbsolute(),
			`@('../../../../../..'->MakeAbsolute())/External/boringssl/include`->MakeAbsolute()
		]
		PreprocessorDefines += [
			"HAVE_CONFIG_H",
			"archive_EXPORTS"
		]
	}
	Property.MalterlibTargetNameType "Normal"
	Compile.AllowNonExisting true
	Target.Group "External/libarchive"
	{
		!!Target.Group undefined
	}
	Target.Type "SharedDynamicLibrary"
	Target.BaseName "libarchive_archive"
	Target.BaseFileName "archive"
