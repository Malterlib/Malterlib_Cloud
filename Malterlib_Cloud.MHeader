Import "../Core/Lib_Malterlib.MTarget"
Import "Apps/*/*.MHeader"
Import "Tools/*/*.MHeader"

%Group "{Malterlib}/{Lib_Malterlib_Cloud}"
{
	Property.MalterlibConcurrency_DistributedActors true
	%Group "Cloud"
	{
		%Group "Include"
		{
			Compile.Type "C++"
			{
				!!DocumentationEnabled true
			}
			%File "Include/Mib/Cloud/^*"
		}
		%File "Source/^*"
		%Group "Documentation"
		{
			%File "Documentation/*"
		}
	}
	%Dependency "Lib_Malterlib_Web"
	{
		Dependency.Indirect true
	}
	%Dependency "Lib_Malterlib_Concurrency"
	{
		Dependency.Indirect true
	}
}

Property
{
	MalterlibCloudCompatibilityTests define bool = false // User(Tests)=true: Set to true to enable compatibility tests for Cloud applications

	MalterlibCloudCompatibilityTestsSupported define bool = false
	MalterlibCloudCompatibilityTestsSupported true
	{
		&
		{
			MalterlibCloudCompatibilityTests true
			|
			{
				&
				{
					Platform "Linux2.6"
					Architecture "x64"
				}
				&
				{
					PlatformFamily "OSX"
					Architecture "x64"
				}
			}
		}
	}

	MalterlibBinaryTestRepositories =+ "Cloud_Linux_x64"
	{
		&
		{
			MalterlibCloudCompatibilityTests true
			EnablePlatform_Linux2_6 true
			EnableArchitecture_x64 true
		}
	}

	MalterlibBinaryTestRepositories =+ "Cloud_OSX_x64"
	{
		&
		{
			MalterlibCloudCompatibilityTests true
			EnablePlatformFamily_OSX true
			EnableArchitecture_x64 true
		}
	}
}

Type
{
	CMalterlibCloudBackupSyncFlags define {
		Pattern: string
		, Flags: [string]
	}

	CMalterlibCloudBackupIncludeWildcards define {
		Pattern: string
		, Destination?: string
	}
}

Property
{
	MalterlibCloudTargetInDependencies define bool = fg_IsTargetInDependencies("Lib_Malterlib_Cloud")

	MalterlibCloudTargetLibrary define bool = false
	MalterlibCloudTarget define bool = false
	MalterlibCloudTarget true
	{
		&
		{
			MalterlibCloudTarget undefined
			|
			{
				MalterlibCloudTargetInDependencies true
				TargetIdentity "Lib_Malterlib_Cloud"
			}
		}
	}

	MalterlibCloudVersionInfo_Branch define string = MalterlibFullBranch
	MalterlibCloudVersionInfo_BranchForVersion define string = MalterlibCloudVersionInfo_Branch->Replace(' ', '')->Replace('(', '-')->Replace(')', '')

	MalterlibCloudVersionInfo_Version define string
	MalterlibCloudVersionInfo_Version MalterlibCloud_VersionUploadVersion
	{
		&
		{
			MalterlibCloudVersionInfo_Version undefined
			!MalterlibCloud_VersionUploadVersion undefined
		}
	}
	MalterlibCloudVersionInfo_Version `@(MalterlibCloudVersionInfo_BranchForVersion)/@(ProductVersionMajor->Format("{}")).@(ProductVersionMinor->Format("{}")).@(ProductVersionRevision->Format("{}"))`
	{
		!!MalterlibCloudVersionInfo_Version undefined
	}

	MalterlibCloudVersionInfo_NoExecutable define bool = false

	MalterlibCloudVersionInfo_Executable define string?
	MalterlibCloudVersionInfo_Executable `@(Target.FileName)@(Target.FileExtension)`
	{
		&
		{
			MalterlibCloudVersionInfo_Executable undefined
			!MalterlibCloudVersionInfo_NoExecutable true
		}
	}

	MalterlibCloudVersionInfo_ExecutableParams define [string]?
	MalterlibCloudVersionInfo_RunAsUser define string?
	MalterlibCloudVersionInfo_RunAsGroup define string?

	MalterlibCloudVersionInfo_Application define string = Target.FileName
	MalterlibCloudVersionInfo_Configuration define string = FullConfiguration
	MalterlibCloudVersionInfo_DistributedApp define bool = true
	MalterlibCloudVersionInfo_RunAsUserHasShell define bool = false
	MalterlibCloudVersionInfo_LowPortExecutables define [string]?
	MalterlibCloudVersionInfo_UpdateScriptEnvironment define {...: string} = {}


	SharedBuildSettingsScriptContents =+	`\r\n`\
											`@(ScriptExport) "MalterlibCloudVersionInfo_Version=@(MalterlibCloudVersionInfo_Version)"\r\n`\
											`@(ScriptExport) "MalterlibCloud_VersionUploadHosts=@(MalterlibCloud_VersionUploadHosts->Join(";"))"\r\n`
	{
	}

	SharedBuildSettingsScriptContents =+	`\r\n`\
											`function UploadToVersionManager()\r\n`\
											`{\r\n`\
											`	local FileName="$1"\r\n`\
											`	shift\r\n`\
											`	local SettingsFile="$1"\r\n`\
											`	shift\r\n`\
											`	UploadHosts=$(echo $MalterlibCloud_VersionUploadHosts | tr ";" "\\n")\r\n`\
											`	for Host in $UploadHosts; do\r\n`\
											`		@(MalterlibCloud_CloudClientCommand) --version-manager-upload-version --no-self-update-check --host $Host --settings-file "$SettingsFile" --tags @(MalterlibCloud_VersionUploadTags->EJSONToString()->EscapeHost())@(MalterlibCloud_VersionUploadCloudClientVersionSpecified)@(MalterlibCloud_VersionUploadCloudClientForceSpecified) "$FileName" "$@@"\r\n`\
											`	done\r\n`\
											`}\r\n`\
											`\r\n`\
											`function UploadToVersionManagerWithInfo()\r\n`\
											`{\r\n`\
											`	local FileName="$1"\r\n`\
											`	shift\r\n`\
											`	local Application="$1"\r\n`\
											`	shift\r\n`\
											`	local Platform="$1"\r\n`\
											`	shift\r\n`\
											`	cat > "${TempDirectory}TempVersionInfo.json" << EOF\r\n`\
											`{\r\n`\
											`	"Application": "$Application"\r\n`\
											`	, "Version": "$MalterlibCloudVersionInfo_Version"\r\n`\
											`	, "Platform": "$Platform"\r\n`\
											`	, "Configuration": "Release"\r\n`\
											`	, "ExtraInfo": {\n`\
											`		"GitBranch": @(MalterlibGitBranch->EJSONToString())\r\n`\
											`		, "GitCommit": @(MalterlibGitCommit->EJSONToString())\r\n`\
											`		, "AppDistribution": {\r\n`\
											`			"DeployDestinations": [$MalterlibCloudVersionInfo_AppDistribution_DeployDestinations]\r\n`\
											`			, "ReleaseNotes": @(MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes->EJSONToString())\r\n`\
											`		}\r\n`\
											`	}\r\n`\
											`}\r\n`\
											`EOF\r\n`\
											`	UploadToVersionManager "$FileName" "${TempDirectory}TempVersionInfo.json"\r\n`\
											`}\r\n`
	{
		!HostPlatformFamily "Windows"
		!!ScriptWindowsBash true
	}

	MalterlibCloudVersionInfo_Backup_IncludeWildcards define [type(CMalterlibCloudBackupIncludeWildcards)]?
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `CommandLineTrustDatabase.@(Target:Target.BaseFileName)/^*`}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `TrustDatabase.@(Target:Target.BaseFileName)/^*`}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `@(Target:Target.BaseFileName)State.json`}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `@(Target:Target.BaseFileName)Config.json`}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `Log/@(Target:Target.BaseFileName)*.log`}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards =+ {Pattern: `Log/CommandLine/@(Target:Target.BaseFileName)*.log`}

	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards define [type(CMalterlibCloudBackupSyncFlags)]?
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards =+ {Pattern: `Log/@(Target:Target.BaseFileName).log`, Flags: ["Append"]}
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards =+ {Pattern: `Log/@(Target:Target.BaseFileName)_??.log`, Flags: ["Append"]}
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards =+ {Pattern: `Log/CommandLine/@(Target:Target.BaseFileName).log`, Flags: ["Append"]}
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards =+ {Pattern: `Log/CommandLine/@(Target:Target.BaseFileName)_??.log`, Flags: ["Append"]}

	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards define [type(CMalterlibCloudBackupSyncFlags)]?


	MalterlibCloudVersionInfo_Backup_ExcludeWildcards define [string]
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards =+ "*/.tmp"
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards =+ "*/.DS_Store"
	{
		!!PlatformFamily "OSX"
	}

	MalterlibCloudVersionInfo_Backup_NewBackupInterval define int?

	MalterlibCloudVersionInfo_AppDistribution_DeployDestinations define [string]?
	MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes define string = ""
}

Property
{
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template function(type(CMalterlibCloudBackupIncludeWildcards) _Wildcard) {
		...: one_of(string, null)
	} = {}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template =+ {`@(_Wildcard<Pattern>)`: _Wildcard<Destination>}
	{
		!_Wildcard<Destination> undefined
	}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template =+ {`@(_Wildcard<Pattern>)`: null}
	{
		!!_Wildcard<Destination> undefined
	}

	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents define {...: one_of(string, null)}
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents MalterlibCloudVersionInfo_Backup_IncludeWildcards->ForEach("MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template")
}

Property
{
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_Template function(type(CMalterlibCloudBackupSyncFlags) _AddFlags) {...: [string]}
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_Template =+ {`@(_AddFlags<Pattern>)`: _AddFlags<Flags>}

	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents define {...: [string]}
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards->ForEach("MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_Template")
}

Property
{
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_Template function(type(CMalterlibCloudBackupSyncFlags) _RemoveFlags) {...: [string]}
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_Template =+ {`@(_RemoveFlags<Pattern>)`: _RemoveFlags<Flags>}

	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents define {...: [string]}
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards->ForEach("MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_Template")
}

Property
{
	MalterlibCloudVersionInfoFileName define string
	MalterlibCloudVersionInfoFileName `@(GeneratedDirectory)@(Target.FileName)VersionInfo.json`
	{
		!!Target.Type "UIExecutable"
		!!Target.Type "Executable"
		!!Target.Type "ConsoleExecutable"
	}

	MalterlibCloudVersionInfo define {...: any}
	MalterlibCloudVersionInfo 	{
									Application: MalterlibCloudVersionInfo_Application
									, Version: MalterlibCloudVersionInfo_Version
									, Platform: MalterlibCloudPlatform
									, Configuration: MalterlibCloudVersionInfo_Configuration
									, ExtraInfo: {
										GitBranch: MalterlibGitBranch
										, GitCommit: MalterlibGitCommit
										, RunAsUserHasShell: MalterlibCloudVersionInfo_RunAsUserHasShell
										, DistributedApp: MalterlibCloudVersionInfo_DistributedApp
										, AppDistribution: {}
										, Backup: {}
										, UpdateScriptEnvironment: MalterlibCloudVersionInfo_UpdateScriptEnvironment
									}
								}

	MalterlibCloudVersionInfo #<ExtraInfo> =+ {Executable: MalterlibCloudVersionInfo_Executable}
	{
		!MalterlibCloudVersionInfo_Executable undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo> =+ {ExecutableParams: MalterlibCloudVersionInfo_ExecutableParams}
	{
		!MalterlibCloudVersionInfo_ExecutableParams undefined
	}
	MalterlibCloudVersionInfo #<ExtraInfo> =+ {RunAsUser: MalterlibCloudVersionInfo_RunAsUser}
	{
		!MalterlibCloudVersionInfo_RunAsUser undefined
	}
	MalterlibCloudVersionInfo #<ExtraInfo> =+ {RunAsGroup: MalterlibCloudVersionInfo_RunAsGroup}
	{
		!MalterlibCloudVersionInfo_RunAsGroup undefined
	}
	MalterlibCloudVersionInfo #<ExtraInfo> =+ {LowPortExecutables: MalterlibCloudVersionInfo_LowPortExecutables}
	{
		!MalterlibCloudVersionInfo_LowPortExecutables undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.AppDistribution> =+ {DeployDestinations: MalterlibCloudVersionInfo_AppDistribution_DeployDestinations}
	{
		!MalterlibCloudVersionInfo_AppDistribution_DeployDestinations undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.AppDistribution> =+ {ReleaseNotes: MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes}
	{
		!MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.Backup>	=+ {IncludeWildcards: MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents}
	{
		!MalterlibCloudVersionInfo_Backup_IncludeWildcards undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.Backup>	=+ {ExcludeWildcards: MalterlibCloudVersionInfo_Backup_ExcludeWildcards}
	{
		!MalterlibCloudVersionInfo_Backup_ExcludeWildcards undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.Backup> =+ {AddSyncFlagsWildcards: MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents}
	{
		!MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.Backup> =+ {RemoveSyncFlagsWildcards: MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents}
	{
		!MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards undefined
	}

	MalterlibCloudVersionInfo #<ExtraInfo.Backup> =+ {NewBackupInterval: MalterlibCloudVersionInfo_Backup_NewBackupInterval}
	{
		!MalterlibCloudVersionInfo_Backup_NewBackupInterval undefined
	}

	MalterlibCloudVersionInfoContents define string
	MalterlibCloudVersionInfoContents MalterlibCloudVersionInfo->EJSONToString()
}

%Group "~Automatic/Malterlib Cloud"
{
	!!TargetIsExecutable true
	%GenerateFile MalterlibCloudTarget_FileIdentity
	{
		GenerateFile
		{
			Name MalterlibCloudVersionInfoFileName
			Contents MalterlibCloudVersionInfoContents
			Executable false
			UnixLineEnds true
			UnicodeBOM false
		}
		Property
		{
			MalterlibCloudTarget_FileIdentity define [string] = []
			MalterlibCloudTarget_FileIdentity ["VersionInfoFile"]
			{
				!!MalterlibCloudTarget true
			}
		}
	}
	%GenerateFile MalterlibCloudTarget_FileIdentityCpp
	{
		GenerateFile
		{
			Name `@(GeneratedDirectory)CloudVersionInfo.cpp`
			Contents 	`#include <Mib/Cloud/VersionInfo>\n`\
						`namespace\n`\
						`{\n`\
						`	struct CRegisterCloudVersion\n`\
						`	{\n`\
						`		CRegisterCloudVersion()\n`\
						`		{\n`\
						`			(*NMib::NCloud::g_CloudVersion) = NMib::NCloud::fg_ParseVersionInfo\n`\
						`				(\n`\
						`R"-----(\n`\
						`@(MalterlibCloudVersionInfoContents)`\
						`)-----"\n`\
						`				)\n`\
						`			;\n`\
						`		}\n`\
						`	};\n`\
						`	assure_used CRegisterCloudVersion g_VersioInfo;\n`\
						`}\n`

			Executable false
			UnixLineEnds true
			UnicodeBOM true
		}
		Property
		{
			MalterlibCloudTarget_FileIdentityCpp define [string] = []
			MalterlibCloudTarget_FileIdentityCpp ["VersionInfoFileCpp"]
			{
				!!MalterlibCloudTarget true
			}
		}
	}
}

Target
{
	ExtraGroups =+ "~Automatic/Malterlib Cloud"
}

Property
{
	MalterlibCloudPlatform define string = `@(Platform->Replace(' ',''))-@(Architecture->Replace(' ',''))`
	MalterlibBuildServerPutSources =+ MalterlibCloudVersionInfoFileName
	{
		&
		{
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}
	MalterlibPostCopySources =+ MalterlibCloudVersionInfoFileName
	{
		&
		{
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}

	MalterlibCloud_EnableVersionUpload define bool = false
}

Compile
{
	&
	{
		CompileDialect "C"
		|
		{
			MalterlibCloudTarget true
			MalterlibCloudTargetLibrary true
		}
	}

	PreprocessorDefines += `DMalterlibCloudPlatform="@(MalterlibCloudPlatform)"`
}

Property
{
	MalterlibLibrary_Cloud define bool = MalterlibLibrary_All
	MalterlibSubLibraries =+ "Cloud"
	{
		!!MalterlibLibrary_Cloud true
	}
	MalterlibLibrarySeparate_Lib_Malterlib_Cloud define bool = true
//	MalterlibSubLibrarySeparate_Lib_Malterlib_Cloud define bool = true
	MalterlibIncludeRoots =+ "Include"->MakeAbsolute()
	{
		!!MalterlibLibrary_Cloud true
	}
}

%Group "{Test}/{Malterlib_Cloud}"
{
	Property.MalterlibConcurrency_DistributedActors true
	Property
	{
		TestBinariesRepoDir define string = `../../Binaries/MalterlibTest/Cloud/@(PlatformFamily)/@(Architecture)`->MakeAbsolute()
	}
	Compile
	{
		!!CompileDialect "C"
		PrefixHeader "Test/PCH.h"->MakeAbsolute()
		PreprocessorDefines += "DMalterlibCloudCompatibilityTests=1"
		{
			!!MalterlibCloudCompatibilityTestsSupported true
		}
	}
	Property
	{
		MalterlibPostCopySources =+ {Pattern: `@(TestBinariesRepoDir)/*`, Destination: "CloudTestBinaries", FindDirectory: true}
		{
			!!MalterlibCloudCompatibilityTestsSupported true
		}
	}
}

Property
{
	&
	{
		MalterlibEnableInternalTests true
	}

	MalterlibTests =+ "Malterlib_Cloud"
	MalterlibTestFiles_Malterlib_Cloud define [type(CEntity)] = ["Test/*"->MakeAbsolute()]
	MalterlibTestDependencies_Malterlib_Cloud define [type(CEntity)] = [
		"Lib_Malterlib_Cloud"
		, {
			Name: "Com_Malterlib_Cloud_AppManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_AppManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_CloudClient"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_CloudClient"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_CloudManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_CloudManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_KeyManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_KeyManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_Test"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_Test"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_VersionManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_VersionManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
			}
		}
		, "Lib_Malterlib_Cloud_AppManager"
		, "Lib_Malterlib_Cloud_BackupManager"
		, "Lib_Malterlib_Cloud_CloudManager"
		, "Lib_Malterlib_Cloud_KeyManager"
		, "Lib_Malterlib_Cloud_SecretsManager"
		, "Lib_Malterlib_Cloud_VersionManager"
		, "Lib_Malterlib_Cloud_Test"
	]
	MalterlibTestExtraGroups_Malterlib_Cloud define [string] = ["{Test}/{Malterlib_Cloud}"]

	Malterlib_Cloud_App_Targets define [type(CEntity)] = []
}

%Workspace "Apps_Malterlib_Cloud"
{
	!!MalterlibEnableInternalWorkspaces true

	Property
	{
		MalterlibCloud_EnableVersionUpload true

		MalterlibPostCopyProject "Malterlib_Cloud"
		{
			!!TargetIsExecutable true
		}

		MalterlibLog_Severities ["Error", "Critical", "Warning", "Info"]
		{
			!!MalterlibLog_EnableVerboseDebugLog false
		}
	}

	%Group "Apps"
	{
		%Target Malterlib_Cloud_App_Targets
	}
}

Property
{
	MalterlibCloud_CloudClientExecutable define string? // User(Cloud Debug)=/opt/Deploy/Malterlib_Cloud/MalterlibCloud: Configure client executable to test local deploy to version manager
	MalterlibCloud_VersionUploadVersion define string? // User(Cloud Debug): Allows you to override the version uploaded to version manager for debug purposes
	MalterlibCloud_VersionUploadForce define bool = false // User(Cloud Debug)=true: Force uploads to version manager even if version already exists
	MalterlibCloud_VersionUploadTags define [string] = [] // User(Cloud Debug)=Debug: Set the tags to use when uploading to version managers
	MalterlibCloud_VersionUploadHostsDefault define [string] = []
	MalterlibCloud_VersionUploadHosts define [string] // User(Cloud Debug): Set the hosts to upload version to
	MalterlibCloud_VersionUploadHosts MalterlibCloud_VersionUploadHostsDefault
	{
		!!MalterlibCloud_VersionUploadHosts undefined
	}

	MalterlibCloud_VersionUploadSources define [type(CFileCopyOptions)] = []
	MalterlibCloud_VersionUploadSources =+ MalterlibBuildServerPutSources
	MalterlibCloud_VersionUploadSources =+ {Pattern: MalterlibCloudVersionInfoFileName, Destination: "VersionInfo.json", AbsoluteDestination: true}
	{
		!MalterlibCloudVersionInfoFileName undefined
	}

	MalterlibCloud_CloudClientCommand define string = "false"
	MalterlibCloud_CloudClientCommand MalterlibCloud_CloudClientExecutable
	{
		!MalterlibCloud_CloudClientExecutable undefined
	}
	MalterlibCloud_VersionUploadToolName define string? = "MalterlibCloud"
	MalterlibCloud_CloudClientCommand `MTool BuildServerTool Tool=@(MalterlibCloud_VersionUploadToolName)`
	{
		&
		{
			MalterlibBuildServerBuild true
			!MalterlibCloud_VersionUploadToolName undefined
		}
	}
}

// Copy temp
Property
{
	MalterlibCloud_VersionUploadTempPath `@(Target.IntermediateDirectory)VersionUpload`

	MalterlibCloud_VersionUploadCopyTempTemplate function(type(CFileCopyOptionsDetailed) _CopyOptions) string
	MalterlibCloud_VersionUploadCopyTempTemplate `MTool DiffCopy @(_CopyOptions<Pattern>->EscapeHost()) @(MalterlibCloud_VersionUploadTempPath->AppendPath(MalterlibCloud_VersionUploadDestinationDir, _CopyOptions<Destination>)->EscapeHost()) "" @(_CopyOptions<Recursive> ? "1" : "0") 0 @(_CopyOptions<FindDirectory> ? "1" : "0") @(_CopyOptions<AbsoluteDestination> ? "1" : "0")\r\n"`\
												 `@(CheckErrors)\r\n`

	MalterlibCloud_VersionUploadCopyTempContents fg_ExpandCopyOptions(MalterlibCloud_VersionUploadSources)->ForEach("MalterlibCloud_VersionUploadCopyTempTemplate")
}

// Upload
Property
{
	MalterlibCloud_VersionUploadCloudClientVersionSpecified define string = ""
	MalterlibCloud_VersionUploadCloudClientVersionSpecified ` --version @(MalterlibCloud_VersionUploadVersion->EscapeHost())`
	{
		!MalterlibCloud_VersionUploadVersion undefined
	}

	MalterlibCloud_VersionUploadCloudClientForceSpecified define string = ""
	MalterlibCloud_VersionUploadCloudClientForceSpecified " --force"
	{
		!!MalterlibCloud_VersionUploadForce true
	}

	MalterlibCloud_VersionUploadCloudClientHostSpecified function(string _Host) string = ""
	MalterlibCloud_VersionUploadCloudClientHostSpecified ` --host @(_Host->EscapeHost())`
	{
		!_Host ""
	}

	MalterlibCloud_VersionUploadToBuildServerPath define string?


	MalterlibCloud_VersionUploadCloudClientCommand	function(string _Host) string
	MalterlibCloud_VersionUploadCloudClientCommand	`@(MalterlibCloud_CloudClientCommand) --version-manager-upload-version --no-self-update-check --settings-file @(MalterlibCloudVersionInfoFileName->EscapeHost()) --tags @(MalterlibCloud_VersionUploadTags->EJSONToString()->EscapeHost())@(MalterlibCloud_VersionUploadCloudClientVersionSpecified)@(MalterlibCloud_VersionUploadCloudClientForceSpecified)@(MalterlibCloud_VersionUploadCloudClientHostSpecified(_Host)) @(MalterlibCloud_VersionUploadTarArchivePath->EscapeHost())\r\n"`\
													`@(CheckErrors)\r\n`
	{
		!!MalterlibCloud_VersionUploadToBuildServerPath undefined
	}

	MalterlibCloud_VersionUploadCloudClientCommand	`MTool BuildServerPut Recursive=0 @(`Source=@(MalterlibCloud_VersionUploadTarArchivePath)`->EscapeHost()) @(`DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)`->EscapeHost())\r\n`\
													`@(CheckErrors)\r\n`\
													`MTool BuildServerPut Recursive=0 @(`Source=@(MalterlibCloudVersionInfoFileName)`->EscapeHost()) @(`DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)`->EscapeHost())\r\n`\
													`@(CheckErrors)\r\n`
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath undefined
			MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientCommand	`@(ScriptExport) @(`MalterlibDeployRoot=@(MalterlibDeployRoot)`->EscapeHost())\r\n`\
													`MTool PostCopy @(`@(MalterlibCloud_VersionUploadTarArchivePath)`->EscapeHost()) @(`Config=@(MalterlibPostCopyConfigFile)`->EscapeHost()) @(`Project=SimulateBuildServerStore`->EscapeHost()) @(`OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)`->EscapeHost())\r\n`\
													`@(CheckErrors)\r\n`\
													`MTool PostCopy @(`@(MalterlibCloudVersionInfoFileName)`->EscapeHost()) @(`Config=@(MalterlibPostCopyConfigFile)`->EscapeHost()) "Project=SimulateBuildServerStore" @(`OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)`->EscapeHost())\r\n`\
													`@(CheckErrors)\r\n`
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath undefined
			!MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientTemplate function(string _Host) string
	MalterlibCloud_VersionUploadCloudClientTemplate	=+ MalterlibCloud_VersionUploadCloudClientCommand(_Host)

	MalterlibCloud_VersionUploadCloudClientContents MalterlibCloud_VersionUploadCloudClientCommand("")
	{
		!!MalterlibCloud_VersionUploadHosts []
	}

	MalterlibCloud_VersionUploadCloudClientContents MalterlibCloud_VersionUploadHosts->ForEach("MalterlibCloud_VersionUploadCloudClientTemplate")
	{
		!MalterlibCloud_VersionUploadHosts []
	}
}

Property
{
	MalterilbCloud_DoVersionManagerUpload define bool = false
	MalterilbCloud_DoVersionManagerUpload true
	{
		&
		{
			MalterlibCloud_EnableVersionUpload true
			|
			{
				!MalterlibCloud_CloudClientExecutable undefined
				&
				{
					MalterlibBuildServerBuild true
					!MalterlibCloud_VersionUploadToolName undefined
				}
				!MalterlibCloud_VersionUploadToBuildServerPath undefined
			}
			!MalterlibCloud_VersionUploadSources []
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}

	MalterlibBuildServerPutDisabled define bool = MalterilbCloud_DoVersionManagerUpload

	MalterlibCloud_VersionUploadTarArchivePath define string = `@(Target.OutputDirectory)@(MalterlibCloudVersionInfo_Application)@(MalterlibCloudVersionInfo_PackageSuffix).tar.gz`
	MalterlibCloud_VersionUploadTarArchivePathTar define string = MalterlibCloud_VersionUploadTarArchivePath

	MalterlibPostBuildScript_Last `@(MalterlibPostBuildScript_Last)`\
					`[ -e @(MalterlibCloud_VersionUploadTempPath->EscapeHost()) ] && rm -rf @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
					`mkdir -p @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
					`@(MalterlibCloud_VersionUploadCopyTempContents)\r\n`\
					`pushd @(MalterlibCloud_VersionUploadTempPath->EscapeHost()) > /dev/null\r\n`\
					`@(CheckErrors)\r\n`\
					`bsdtar @(TarOptions) -czf @(MalterlibCloud_VersionUploadTarArchivePathTar->EscapeHost()) .\r\n`\
					`@(CheckErrors)\r\n`\
					`popd > /dev/null\r\n`\
					`@(CheckErrors)\r\n`\
					`@(MalterlibCloud_VersionUploadCloudClientContents)\r\n`
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			!GeneratorFamily "VisualStudio"
		}
	}

	MalterlibPostBuildScript_Last `@(MalterlibPostBuildScript_Last)`\
					`IF EXIST @(MalterlibCloud_VersionUploadTempPath->EscapeHost()) rmdir /s /q @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
					`mkdir @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
					`@(MalterlibCloud_VersionUploadCopyTempContents)\r\n`\
					`pushd @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
					`@(CheckErrors)\r\n`\
					`bsdtar @(TarOptions) -czf @(MalterlibCloud_VersionUploadTarArchivePathTar->EscapeHost()) .\r\n`\
					`@(CheckErrors)\r\n`\
					`popd\r\n`\
					`@(CheckErrors)\r\n`\
					`@(MalterlibCloud_VersionUploadCloudClientContents)\r\n`
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			GeneratorFamily "VisualStudio"
		}
	}
}

%Group "{Malterlib}/{CloudTarBinaries}"
{
	Property
	{
		MalterlibCloudTarBinDirectory define string = "bin"
		BsdTarGenerateScheme define {...: any} = {}
		BsdTarGenerateScheme =+ {
			Target.GenerateScheme: false
		}
		{
			!!GeneratorFamily "Xcode"
		}
	}

	%Dependency [
		{
			Name: `Com_@(Target:Target.BaseName)_bsdtar`
			, Properties: {
				Dependency.Target: "Exe_bsdtar"
				, Dependency.TargetProperties: {
					MalterlibPostCopyProject: MalterlibPostCopyProject
					, MalterlibPostCopyDestination: `@(MalterlibPostCopyDestination)@(MalterlibCloudTarBinDirectory)/`
					, Target.Name: `Com_@(Target:Target.BaseName)_bsdtar`
					, Target.Group: `ExternalBinaries/@(Target:Target.BaseName)`
					, <<: BsdTarGenerateScheme
				}
			}
		}
	]
	{
		Dependency.Link false
	}

	Property
	{
		MalterlibCloud_VersionUploadSources =+ {
			Pattern: GetProperty("Property", "MalterlibFinalModuleDestination", `Group:ExternalBinaries.Group:@(Target:Target.BaseName).Target:Exe_bsdtar.Target:Exe_bsdtar`)
			, Destination: MalterlibCloudTarBinDirectory
		}
	}
}
