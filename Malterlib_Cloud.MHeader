		}
		, "Lib_Malterlib_Cloud_AppManager"
		, "Lib_Malterlib_Cloud_BackupManager"
		, "Lib_Malterlib_Cloud_CloudManager"
		, "Lib_Malterlib_Cloud_KeyManager"
		, "Lib_Malterlib_Cloud_SecretsManager"
		, "Lib_Malterlib_Cloud_VersionManager"
		, "Lib_Malterlib_Cloud_Test"
	]
	MalterlibTestExtraGroups_Malterlib_Cloud: [string] = ["{Test}/{Malterlib_Cloud}"]
}

%Workspace "Apps_Malterlib_Cloud"
{
	!!MalterlibEnableInternalWorkspaces true

	Property
	{
		MalterlibCloud_EnableVersionUpload true
		{
			!!TargetIsExecutable true
		}

		MalterlibPostCopyProject "Malterlib_Cloud"
		{
			!!TargetIsExecutable true
		}

		MalterlibLog_Severities ["Error", "Critical", "Warning", "Info"]
		{
			!!MalterlibLog_EnableVerboseDebugLog false
		}
	}

	%Group "Apps"
	{
		%Target Malterlib_Cloud_App_Targets
	}

	Workspace.ExtraGroups =+ Malterlib_Cloud_App_ExtraGroups
}

Property
{
	MalterlibCloud_CloudClientExecutable: string? // User(Cloud Debug)="/opt/Deploy/Malterlib_Cloud/MalterlibCloud": Configure client executable to test local deploy to version manager
	MalterlibCloud_VersionUploadVersion: string? // User(Cloud Debug): Allows you to override the version uploaded to version manager for debug purposes
	MalterlibCloud_VersionUploadForce: bool = false // User(Cloud Debug)=true: Force uploads to version manager even if version already exists
	MalterlibCloud_VersionUploadTags: [string] = [] // User(Cloud Debug)=["Debug"]: Set the tags to use when uploading to version managers
	MalterlibCloud_VersionUploadHostsDefault: [string] = []
	MalterlibCloud_VersionUploadHosts: [string] // User(Cloud Debug): Set the hosts to upload version to
	MalterlibCloud_VersionUploadHosts MalterlibCloud_VersionUploadHostsDefault
	{
		!!MalterlibCloud_VersionUploadHosts undefined
	}

	MalterlibCloud_VersionUploadSources: [type(CFileCopyOptions)] = []
	MalterlibCloud_VersionUploadSources =+ MalterlibBuildServerPutSources
	MalterlibCloud_VersionUploadSources =+ {Pattern: MalterlibCloudVersionInfoFileName, Destination: "VersionInfo.json", AbsoluteDestination: true}
	{
		!MalterlibCloudVersionInfoFileName undefined
	}

	MalterlibCloud_CloudClientCommand: string = "false"
	MalterlibCloud_CloudClientCommand MalterlibCloud_CloudClientExecutable
	{
		!MalterlibCloud_CloudClientExecutable undefined
	}
	MalterlibCloud_VersionUploadToolName: string? = "MalterlibCloud"
	MalterlibCloud_CloudClientCommand `@(MalterlibBuildServerCommandPrefix)MTool BuildServerTool Tool=@(MalterlibCloud_VersionUploadToolName)`
	{
		&
		{
			MalterlibBuildServerBuild true
			!MalterlibCloud_VersionUploadToolName undefined
		}
	}
}

// Copy temp
Property
{
	MalterlibCloud_VersionUploadTempPath: string = `@(Target.IntermediateDirectory)VersionUpload`
	MalterlibCloud_VersionUploadDestinationDir: string = ""

	MalterlibCloud_VersionUploadCopyTempTemplate function(type(CFileCopyOptionsDetailed) _CopyOptions) string = ""
	MalterlibCloud_VersionUploadCopyTempTemplate =+	`MTool DiffCopy @(_CopyOptions<Pattern>->EscapeHost()) @(MalterlibCloud_VersionUploadTempPath->AppendPath(MalterlibCloud_VersionUploadDestinationDir, _CopyOptions<Destination>)->EscapeHost()) "" @(_CopyOptions<Recursive> ? "1" : "0") 0 @(_CopyOptions<FindDirectory> ? "1" : "0") @(_CopyOptions<AbsoluteDestination> ? "1" : "0")\r\n`

	MalterlibCloud_VersionUploadCopyTempContents: string
	MalterlibCloud_VersionUploadCopyTempContents =+ fg_ExpandCopyOptions(MalterlibCloud_VersionUploadSources)->ForEach(&MalterlibCloud_VersionUploadCopyTempTemplate)
}

// Upload
Property
{
	MalterlibCloud_VersionUploadCloudClientVersionSpecified: string = ""
	MalterlibCloud_VersionUploadCloudClientVersionSpecified ` --version @(MalterlibCloud_VersionUploadVersion->EscapeHost())`
	{
		!MalterlibCloud_VersionUploadVersion undefined
	}

	MalterlibCloud_VersionUploadCloudClientForceSpecified: string = ""
	MalterlibCloud_VersionUploadCloudClientForceSpecified " --force"
	{
		!!MalterlibCloud_VersionUploadForce true
	}

	MalterlibCloud_VersionUploadCloudClientHostSpecified function([string] _Hosts) string = ""
	MalterlibCloud_VersionUploadCloudClientHostSpecified ` --hosts "@(_Hosts->Join(","))"`
	{
		!_Hosts []
	}

	MalterlibCloud_VersionUploadToBuildServerPath: string?
	MalterlibCloud_VersionUploadToBuildServerPathFull: string? = MalterlibCloud_VersionUploadToBuildServerPath / MalterlibCloudPlatform

	MalterlibCloud_VersionUploadCloudClientCommand	function([string] _Hosts) string
	MalterlibCloud_VersionUploadCloudClientCommand	`@(MalterlibCloud_CloudClientCommand) --version-manager-upload-version --no-self-update-check --settings-file @(MalterlibCloudVersionInfoFileName->EscapeHost()) --tags @(MalterlibCloud_VersionUploadTags->EJSONToString("")->EscapeHost())@(MalterlibCloud_VersionUploadCloudClientVersionSpecified)@(MalterlibCloud_VersionUploadCloudClientForceSpecified)@(MalterlibCloud_VersionUploadCloudClientHostSpecified(_Hosts)) @(MalterlibCloud_VersionUploadTarArchivePath->EscapeHost())\r\n`
	{
		!!MalterlibCloud_VersionUploadToBuildServerPath undefined
	}

	MalterlibCloud_VersionUploadCloudClientCommand	`@(MalterlibBuildServerCommandPrefix)MTool BuildServerPut Recursive=0 @(`Source=@(MalterlibCloud_VersionUploadTarArchivePath)`->EscapeHost()) @(`DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPathFull)`->EscapeHost())\r\n`\
													`@(MalterlibBuildServerCommandPrefix)MTool BuildServerPut Recursive=0 @(`Source=@(MalterlibCloudVersionInfoFileName)`->EscapeHost()) @(`DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPathFull)`->EscapeHost())\r\n`
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath undefined
			MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientCommand	`@(ScriptExport("MalterlibDeployRoot", MalterlibDeployRoot))\r\n`\
													`MTool PostCopy @(`@(MalterlibCloud_VersionUploadTarArchivePath)`->EscapeHost()) @(`Config=@(MalterlibPostCopyConfigFile)`->EscapeHost()) @(`Project=SimulateBuildServerStore`->EscapeHost()) @(`OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPathFull)`->EscapeHost())\r\n`\
													`MTool PostCopy @(`@(MalterlibCloudVersionInfoFileName)`->EscapeHost()) @(`Config=@(MalterlibPostCopyConfigFile)`->EscapeHost()) "Project=SimulateBuildServerStore" @(`OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPathFull)`->EscapeHost())\r\n`
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath undefined
			!MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientContents: string = ""

	MalterlibCloud_VersionUploadCloudClientContents MalterlibCloud_VersionUploadCloudClientCommand([])
	{
		!!MalterlibCloud_VersionUploadHosts []
	}

	MalterlibCloud_VersionUploadCloudClientContents MalterlibCloud_VersionUploadCloudClientCommand(MalterlibCloud_VersionUploadHosts)
	{
		!MalterlibCloud_VersionUploadHosts []
	}
}

Property
{
	MalterilbCloud_DoVersionManagerUpload: bool = false

	MalterlibBuildServerPutDisabled: bool = MalterilbCloud_DoVersionManagerUpload

	MalterlibCloud_VersionUploadTarArchivePath: string = `@(Target.OutputDirectory)@(MalterlibCloudVersionInfo_Application)@(MalterlibCloudVersionInfo_PackageSuffix)@(MalterlibCloudVersionInfo_PackageExtension)`
	MalterlibCloud_VersionUploadTarArchivePathTar: string = MalterlibCloud_VersionUploadTarArchivePath

	MalterlibPostBuildScript_Last =+	`[ -e @(MalterlibCloud_VersionUploadTempPath->EscapeHost()) ] && rm -rf @(MalterlibCloud_VersionUploadTempPath->EscapeHost())\r\n`\
										`@(ScriptMkDir(MalterlibCloud_VersionUploadTempPath))\r\n`\
										`@(MalterlibCloud_VersionUploadCopyTempContents)\r\n`\
										`pushd @(MalterlibCloud_VersionUploadTempPath->EscapeHost()) > /dev/null\r\n`\
										`bsdtar @(TarOptions) -c @(TarCompressionOptions) -f @(MalterlibCloud_VersionUploadTarArchivePathTar->EscapeHost()) .\r\n`\
										`popd > /dev/null\r\n`\
										`@(MalterlibCloud_VersionUploadCloudClientContents)\r\n`
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			!ScriptWindowsBat true
		}
	}

	MalterlibPostBuildScript_Last =+	`IF EXIST @(MalterlibCloud_VersionUploadTempPath->NativePath()->EscapeHost()) rmdir /s /q @(MalterlibCloud_VersionUploadTempPath->NativePath()->EscapeHost())\r\n`\
										`mkdir @(MalterlibCloud_VersionUploadTempPath->NativePath()->EscapeHost())\r\n`\
										`@(MalterlibCloud_VersionUploadCopyTempContents)\r\n`\
										`pushd @(MalterlibCloud_VersionUploadTempPath->NativePath()->EscapeHost())\r\n`\
										`bsdtar @(TarOptions) -c @(TarCompressionOptions) -f @(MalterlibCloud_VersionUploadTarArchivePathTar->NativePath()->EscapeHost()) *\r\n`\
										`popd\r\n`\
										`@(MalterlibCloud_VersionUploadCloudClientContents)\r\n`
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			ScriptWindowsBat true
		}
	}

	MalterlibPostBuildScriptInputs =+ fg_ExpandCopyOptions(MalterlibCloud_VersionUploadSources)->ForEach(&f_ExtractPlainFilesFromCopyOptions)
	{
		!!MalterilbCloud_DoVersionManagerUpload true
	}
}

%Group "{Malterlib}/{CloudTarBinaries}"
{
	Property
	{
		MalterlibCloudTarBinDirectory: string = "bin"
		BsdTarGenerateScheme: {...: any} = {}
		BsdTarGenerateScheme =+ {
			"Target.GenerateScheme": false
		}

		BsdTarUniqueName: string = `@(MalterlibPostCopyProject)_@(MalterlibPostCopyDestination)@(MalterlibCloudTarBinDirectory)`->Replace("/", "_")
	}

	%Dependency [
		{
			Name: `Com_@(BsdTarUniqueName)_bsdtar`
			, Properties: {
				Dependency.Target: "Com_libarchive_bsdtar"
				, Dependency.TargetProperties: {
					MalterlibPostCopyProject: MalterlibPostCopyProject
					, MalterlibPostCopyDestination: MalterlibPostCopyDestination / MalterlibCloudTarBinDirectory
					, Target.Name: `Com_@(BsdTarUniqueName)_bsdtar`
					, Target.Group: `ExternalBinaries/@(BsdTarUniqueName)`
					, <<: BsdTarGenerateScheme
				}
			}
		}
	]
	{
		Dependency.Link false
	}

	Property
	{
		MalterlibCloud_VersionUploadSources =+ GetProperty(&MalterlibBuildServerPutSources, `Group:ExternalBinaries.Group:@(BsdTarUniqueName).Target:Com_libarchive_bsdtar.Import:*.Target:Com_libarchive_bsdtar`)->f_AddDestinationPrefixToCopyOptions(MalterlibCloudTarBinDirectory)
	}
}
