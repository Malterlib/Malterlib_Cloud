			Name: "Com_Malterlib_Cloud_AppManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_AppManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
				, Dependency.Link: false
				, Dependency.Stage: "Runtime"
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_CloudClient"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_CloudClient"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
				, Dependency.Link: false
				, Dependency.Stage: "Runtime"
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_CloudManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_CloudManager"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
				, Dependency.Link: false
				, Dependency.Stage: "Runtime"
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_KeyManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_KeyManager"
