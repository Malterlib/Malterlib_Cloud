Import "../Core/Lib_Malterlib.MTarget"
Import "Apps/*/*.MHeader"
Import "Tools/*/*.MHeader"

%Group "{Malterlib}/{Lib_Malterlib_Cloud}"
{
	Property.MalterlibConcurrency_DistributedActors true
	%Group Cloud
	{
		%Group Include
		{
			Compile.Type "C++"
			{
				!!DocumentationEnabled true
			}
			%File "Include/Mib/Cloud/^*"
		}
		%File "Source/*"
		%Group Documentation
		{
			%File "Documentation/*"
		}
	}
	%Dependency Lib_Malterlib_Web
	{
		Dependency.Indirect true
	}
	%Dependency Lib_Malterlib_Concurrency
	{
		Dependency.Indirect true
	}	
}

Property
{
	MalterlibCloudTargetInDependenciesTemplate_TargetName "@(Builtin.Function->GetProperty('Property', 'TargetIdentity', '@(Explodee)'))"
	{
	}
	
	MalterlibCloudTargetInDependenciesTemplate true
	{
		!!MalterlibCloudTargetInDependenciesTemplate_TargetName "Lib_Malterlib_Cloud"
	}
	
	MalterlibCloudTargetInDependencies "@(Builtin.Function->ExplodeList('@(Target.Dependencies)', ';', 'MalterlibCloudTargetInDependenciesTemplate'))"
	
	MalterlibCloudTarget true
	{
		&
		{
			MalterlibCloudTarget ""
			|
			{
				MalterlibCloudTargetInDependencies true
				TargetIdentity "Lib_Malterlib_Cloud"
			}
		}
	}
	
	MalterlibCloudVersionInfo_Branch "@(MalterlibFullBranch)"
	{
		!!MalterlibCloudVersionInfo_Branch ""
	}
	
	MalterlibCloudVersionInfo_BranchForVersion "@(MalterlibCloudVersionInfo_Branch->Replace(' ', ''))"
	MalterlibCloudVersionInfo_BranchForVersion "@(MalterlibCloudVersionInfo_BranchForVersion->Replace('(', '-'))"
	MalterlibCloudVersionInfo_BranchForVersion "@(MalterlibCloudVersionInfo_BranchForVersion->Replace(')', ''))"

	MalterlibCloudVersionInfo_Version "@(MalterlibCloud_VersionUploadVersion)"
	{
		&
		{
			MalterlibCloudVersionInfo_Version ""
			!MalterlibCloud_VersionUploadVersion ""
		}
	}
	MalterlibCloudVersionInfo_Version "@(MalterlibCloudVersionInfo_BranchForVersion)/@(ProductVersionMajor->FormatInt('{}')).@(ProductVersionMinor->FormatInt('{}')).@(ProductVersionRevision->FormatInt('{}'))"
	{
		!!MalterlibCloudVersionInfo_Version ""
	}
	MalterlibCloudVersionInfo_Executable "@(Target.FileName)@(Target.FileExtension)"
	{
		&
		{
			MalterlibCloudVersionInfo_Executable ""
			!MalterlibCloudVersionInfo_NoExecutable true
		}
	}
	MalterlibCloudVersionInfo_Application "@(Target.FileName)"
	{
		!!MalterlibCloudVersionInfo_Application ""
	}
	MalterlibCloudVersionInfo_Configuration "@(FullConfiguration)"
	{
		!!MalterlibCloudVersionInfo_Configuration ""
	}
	MalterlibCloudVersionInfo_DistributedApp true
	{
		!!MalterlibCloudVersionInfo_DistributedApp ""
	}
	MalterlibCloudVersionInfo_RunAsUserHasShell false
	{
		!!MalterlibCloudVersionInfo_RunAsUserHasShell ""
	}
	
	SharedBuildSettingsScriptContents	"@(SharedBuildSettingsScriptContents)"\
										"\r\n"\
										"@(ScriptExport) \"MalterlibCloudVersionInfo_Version=@(MalterlibCloudVersionInfo_Version)\"\r\n"\
										"@(ScriptExport) \"MalterlibCloud_VersionUploadHosts=@(MalterlibCloud_VersionUploadHosts)\"\r\n"
	{
	}

	SharedBuildSettingsScriptContents	"@(SharedBuildSettingsScriptContents)"\
										"\r\n"\
										"function UploadToVersionManager()\r\n"\
										"{\r\n"\
										"	UploadHosts=$(echo $MalterlibCloud_VersionUploadHosts | tr \";\" \"\\n\")\r\n"\
										"	for Host in $UploadHosts; do\r\n"\
										"		MTool BuildServerTool Tool=@(MalterlibCloud_VersionUploadToolName) --no-self-update-check --version-manager-upload-version --host $Host --settings-file \"$2\" \"$1\"\r\n"\
										"	done\r\n"\
										"}\r\n"\
										"\r\n"\
										"function UploadToVersionManagerWithInfo()\r\n"\
										"{\r\n"\
										"	cat > \"${TempDirectory}TempVersionInfo.json\" << EOF\r\n"\
										"{\r\n"\
										"	\"Application\": \"$2\"\r\n"\
										"	, \"Version\": \"$MalterlibCloudVersionInfo_Version\"\r\n"\
										"	, \"Platform\": \"$3\"\r\n"\
										"	, \"Configuration\": \"Release\"\r\n"\
										"}\r\n"\
										"EOF\r\n"\
										"	UploadToVersionManager \"$1\" \"${TempDirectory}TempVersionInfo.json\"\r\n"\
										"}\r\n"
	{
		!HostPlatformFamily Windows
		!!ScriptWindowsBash true
	}

	MalterlibCloudVersionInfo_Backup_IncludeWildcards "CommandLineTrustDatabase.@(Target:Target.BaseFileName)/^*;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards "TrustDatabase.@(Target:Target.BaseFileName)/^*;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards "@(Target:Target.BaseFileName)State.json;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards "@(Target:Target.BaseFileName)Config.json;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards "Log/@(Target:Target.BaseFileName)*.log;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards "Log/CommandLine/@(Target:Target.BaseFileName)*.log;@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)"

	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards "Log/@(Target:Target.BaseFileName).log=Append;@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards)"
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards "Log/@(Target:Target.BaseFileName)_??.log=Append;@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards)"
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards "Log/CommandLine/@(Target:Target.BaseFileName).log=Append;@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards)"
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards "Log/CommandLine/@(Target:Target.BaseFileName)_??.log=Append;@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards)"

	MalterlibCloudVersionInfo_Backup_ExcludeWildcards "*/.tmp;@(MalterlibCloudVersionInfo_Backup_ExcludeWildcards)"
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards "*/.DS_Store;@(MalterlibCloudVersionInfo_Backup_ExcludeWildcards)"
	{
		!!PlatformFamily OSX
	}
}

Property
{
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_ExpandTemplate "\"@(Expand0)\": \"@(Expand1)\""
	{
		!Expand1 ""
	}
	
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_ExpandTemplate "\"@(Expand0)\": null"
	{
		!!Expand1 ""
	}
	
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template ", @(Builtin.Function->ExpandList('@(Explodee)', '=', 'MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_ExpandTemplate'))"
	{
		!Explodee ""
	}

	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents "{Dummy@(Builtin.Function->ExplodeList('@(MalterlibCloudVersionInfo_Backup_IncludeWildcards)', ';', 'MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents_Template'))}"
	
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents->Replace('Dummy, ', ''))"
	MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents->Replace('{Dummy}', '{}'))"
}

Property
{
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents_Template ", \"@(Explodee)\""
	{
		!Explodee ""
	}

	MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents "[Dummy@(Builtin.Function->ExplodeList('@(MalterlibCloudVersionInfo_Backup_ExcludeWildcards)', ';', 'MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents_Template'))]"
	
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents->Replace('Dummy, ', ''))"
	MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents->Replace('[Dummy]', '[]'))"
}
	
Property
{
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_InnerTemplate ", \"@(Explodee)\""
	{
		!Explodee ""
	}
	
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_ExpandTemplate "\"@(Expand0)\": [Dummy@(Builtin.Function->ExplodeList('@(Expand1)', ',', 'MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_InnerTemplate'))]"
	
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_Template ", @(Builtin.Function->ExpandList('@(Explodee)', '=', 'MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_ExpandTemplate'))"
	{
		!Explodee ""
	}

	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents "{Dummy@(Builtin.Function->ExplodeList('@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards)', ';', 'MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents_Template'))}"
	
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents->Replace('Dummy, ', ''))"
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents->Replace('{Dummy}', '{}'))"
	MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents->Replace('[Dummy]', '[]'))"
}

Property
{
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_InnerTemplate ", \"@(Explodee)\""
	{
		!Explodee ""
	}
	
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_ExpandTemplate "\"@(Expand0)\": [Dummy@(Builtin.Function->ExplodeList('@(Expand1)', ',', 'MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_InnerTemplate'))]"
	
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_Template ", @(Builtin.Function->ExpandList('@(Explodee)', '=', 'MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_ExpandTemplate'))"
	{
		!Explodee ""
	}

	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents "{Dummy@(Builtin.Function->ExplodeList('@(MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards)', ';', 'MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents_Template'))}"
	
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents->Replace('Dummy, ', ''))"
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents->Replace('[Dummy]', '[]'))"
	MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents "@(MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents->Replace('{Dummy}', '{}'))"
}

Property
{
	MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents_Template ", \"@(Explodee)\""
	{
		!Explodee ""
	}

	MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents "[Dummy@(Builtin.Function->ExplodeList('@(MalterlibCloudVersionInfo_AppDistribution_DeployDestinations)', ';', 'MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents_Template'))]"

	MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents "@(MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents->Replace('Dummy, ', ''))"
	MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents "@(MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents->Replace('[Dummy]', '[]'))"
}

Property
{
	NewLine "\n"
	MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes_Escaped "@(MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes->Replace('@(NewLine)','\\\\n'))"
}


Property
{
	MalterlibCloudVersionInfoFileName "@(GeneratedDirectory)@(Target.FileName)VersionInfo.json"
	{
		!!Target.Type "UIExecutable"
		!!Target.Type "Executable"
		!!Target.Type "ConsoleExecutable"
	}
	
	MalterlibCloudVersionInfo	"{\n"\
								"\t\"Application\": \"@(MalterlibCloudVersionInfo_Application)\"\n"\
								"\t, \"Version\": \"@(MalterlibCloudVersionInfo_Version)\"\n"\
								"\t, \"Platform\": \"@(MalterlibCloudPlatform)\"\n"\
								"\t, \"Configuration\": \"@(MalterlibCloudVersionInfo_Configuration)\"\n"\
								"\t, \"ExtraInfo\": {\n"\
								"\t\t\"Dummy\": null\n"\
								"\t\t, \"GitBranch\": \"@(MalterlibGitBranch)\"\n"\
								"\t\t, \"GitCommit\": \"@(MalterlibGitCommit)\"\n"

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"Executable\": \"@(MalterlibCloudVersionInfo_Executable)\"\n"
	{
		!MalterlibCloudVersionInfo_Executable ""
	}
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"ExecutableParams\": \"@(MalterlibCloudVersionInfo_ExecutableParams)\"\n"
	{
		!MalterlibCloudVersionInfo_ExecutableParams ""
	}
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"RunAsUser\": \"@(MalterlibCloudVersionInfo_RunAsUser)\"\n"
	{
		!MalterlibCloudVersionInfo_RunAsUser ""
	}
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"RunAsGroup\": \"@(MalterlibCloudVersionInfo_RunAsGroup)\"\n"
	{
		!MalterlibCloudVersionInfo_RunAsGroup ""
	}
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"RunAsUserHasShell\": @(MalterlibCloudVersionInfo_RunAsUserHasShell)\n"
	{
		!MalterlibCloudVersionInfo_RunAsUserHasShell ""
	}
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"DistributedApp\": @(MalterlibCloudVersionInfo_DistributedApp)\n"
	{
		!MalterlibCloudVersionInfo_DistributedApp ""
	}

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"AppDistribution\": {\n"\
								"\t\t\t\"Dummy\": null\n"

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"DeployDestinations\": @(MalterlibCloudVersionInfo_AppDistribution_DeployDestinations_Contents)\n"
	{
		!MalterlibCloudVersionInfo_AppDistribution_DeployDestinations ""
	}

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"ReleaseNotes\": \"@(MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes_Escaped)\"\n"
	{
		!MalterlibCloudVersionInfo_AppDistribution_ReleaseNotes ""
	}

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t}\n"

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t, \"Backup\": {\n"\
								"\t\t\t\"Dummy\": null\n"

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"IncludeWildcards\": @(MalterlibCloudVersionInfo_Backup_IncludeWildcards_Contents)\n"
	{
		!MalterlibCloudVersionInfo_Backup_IncludeWildcards ""
	}

	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"ExcludeWildcards\": @(MalterlibCloudVersionInfo_Backup_ExcludeWildcards_Contents)\n"
	{
		!MalterlibCloudVersionInfo_Backup_ExcludeWildcards ""
	}
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"AddSyncFlagsWildcards\": @(MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards_Contents)\n"
	{
		!MalterlibCloudVersionInfo_Backup_AddSyncFlagsWildcards ""
	}
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"RemoveSyncFlagsWildcards\": @(MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards_Contents)\n"
	{
		!MalterlibCloudVersionInfo_Backup_RemoveSyncFlagsWildcards ""
	}
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t\t, \"NewBackupInterval\": @(MalterlibCloudVersionInfo_Backup_NewBackupInterval)\n"
	{
		!MalterlibCloudVersionInfo_Backup_NewBackupInterval ""
	}
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t\t}\n"
	
	MalterlibCloudVersionInfo	"@(MalterlibCloudVersionInfo)"\
								"\t}\n"\
								"}\n"
	
	MalterlibCloudVersionInfo "@(MalterlibCloudVersionInfo->Replace('\"Dummy\": null\\\n\t\t\t, ', ''))"
	MalterlibCloudVersionInfo "@(MalterlibCloudVersionInfo->Replace('\t\t\t\"Dummy\": null\\\n', ''))"
	MalterlibCloudVersionInfo "@(MalterlibCloudVersionInfo->Replace('\"Dummy\": null\\\n\t\t, ', ''))"
	MalterlibCloudVersionInfo "@(MalterlibCloudVersionInfo->Replace('\t\t\"Dummy\": null\\\n', ''))"

	MalterlibCloudVersionInfoCppFileName "@(GeneratedDirectory)CloudVersionInfo.h"
	
	MalterlibCloudVersionInfoCpp	"#include <Mib/Cloud/VersionInfo>\n"\ 
									"namespace\n"\
									"{\n"\
									"	NMib::NCloud::CCloudVersionInfo fg_GetCloudVersionInfo()\n"\
									"	{\n"\
									"		return NMib::NCloud::fg_ParseVersionInfo\n"\
									"			(\n"\
									"R\"-----(\n"\
									"@(MalterlibCloudVersionInfo)"\
									")-----\"\n"\
									"			)\n"\
									"		;\n"\
									"	}\n"\
									"}\n"
}

%Group "~Automatic/Malterlib Cloud"
{
	!!TargetIsExecutable true
	%GenerateFile "@(MalterlibCloudTarget_FileIdentity)"
	{
		Property
		{
			Name "@(MalterlibCloudVersionInfoFileName)"
			Contents "@(MalterlibCloudVersionInfo)"
			Executable false
			UnixLineEnds true
			UnicodeBOM false
			MalterlibCloudTarget_FileIdentity VersionInfoFile
			{
				!!MalterlibCloudTarget true
			}
		}
	}
	%GenerateFile "@(MalterlibCloudTarget_FileIdentityCpp)"
	{
		Property
		{
			Name "@(MalterlibCloudVersionInfoCppFileName)"
			Contents "@(MalterlibCloudVersionInfoCpp)"
			Executable false
			UnixLineEnds true
			UnicodeBOM true
			MalterlibCloudTarget_FileIdentityCpp VersionInfoFileCpp
			{
				!!MalterlibCloudTarget true
			}
		}
	}
}

Target
{
	ExtraGroups "~Automatic/Malterlib Cloud;@(Target.ExtraGroups)"
}

Property
{
	MalterlibCloudPlatform "@(Platform->Replace(' ',''))-@(Architecture->Replace(' ',''))"
	{
		!!MalterlibCloudPlatform ""
	}
	MalterlibBuildServerPutSources "@(MalterlibCloudVersionInfoFileName);@(MalterlibBuildServerPutSources)"
	{
		&	
		{
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}
	MalterlibPostCopySources "@(MalterlibCloudVersionInfoFileName);@(MalterlibPostCopySources)"
	{
		&	
		{
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}
}

Compile
{
	&
	{
		CompileDialect C
		|
		{
			MalterlibCloudTarget true
			MalterlibCloudTargetLibrary true
		}
	}
	
	PreprocessorDefines "DMalterlibCloudPlatform=\"@(MalterlibCloudPlatform)\";@(Compile.PreprocessorDefines)"
}

Property
{
	MalterlibLibrary_Cloud true
	{
		&
		{
			MalterlibLibrary_Cloud ""
			MalterlibLibrary_All true
		}
	}
	MalterlibSubLibraries "Cloud;@(MalterlibSubLibraries)"
	{
		!!MalterlibLibrary_Cloud true
	}
	MalterlibLibrarySeparate_Lib_Malterlib_Cloud true
//	MalterlibSubLibrarySeparate_Lib_Malterlib_Cloud true
	MalterlibIncludeRoots "@('Include'->MakeAbsolute());@(MalterlibIncludeRoots)"
	{
		!!MalterlibLibrary_Cloud true
	}
}

%Group "{Test}/{Malterlib_Cloud}"
{
	Property.MalterlibConcurrency_DistributedActors true
	Property
	{
		MalterlibLinkWithOpenSSL true
	}
	Compile
	{
		!!CompileDialect "C"
		PrefixHeader "@('Test/PCH.h'->MakeAbsolute())"
	}
}

Property
{
	&
	{
		MalterlibEnableInternalTests true
	}

	MalterlibTests "Malterlib_Cloud;@(MalterlibTests)"
	MalterlibTestFiles_Malterlib_Cloud "@('Test/*'->MakeAbsolute())"
	MalterlibTestDependencies_Malterlib_Cloud "Lib_Malterlib_Cloud;Malterlib_Cloud_AppManager=Com_Malterlib_Cloud_AppManager*MalterlibGenerateScheme=false;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Malterlib_Cloud_VersionManager=Com_Malterlib_Cloud_VersionManager*MalterlibGenerateScheme=false;Lib_Malterlib_Cloud_VersionManager;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Malterlib_Cloud_Test=Com_Malterlib_Cloud_Test*MalterlibGenerateScheme=false;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Malterlib_Cloud_CloudClient=Com_Malterlib_Cloud_CloudClient*MalterlibGenerateScheme=false;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Malterlib_Cloud_KeyManager=Com_Malterlib_Cloud_KeyManager*MalterlibGenerateScheme=false;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Lib_Malterlib_Cloud_SecretsManager;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Lib_Malterlib_Cloud_KeyManager;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestDependencies_Malterlib_Cloud "Lib_Malterlib_Cloud_BackupManager;@(MalterlibTestDependencies_Malterlib_Cloud)"
	MalterlibTestExtraGroups_Malterlib_Cloud "{Test}/{Malterlib_Cloud}"
}

%Workspace "Apps_Malterlib_Cloud"
{
	&
	{
		MalterlibEnableInternalWorkspaces true
	}
	
	Property
	{
		MalterlibCloud_EnableVersionUpload true

		MalterlibPostCopyProject "Malterlib_Cloud"
		{
			!!TargetIsExecutable true
		}
	
		MalterlibLog_Severities "Error;Critical;Warning;Info"
		{
			!!MalterlibLog_EnableVerboseDebugLog false
		}
	}

	%Group Apps
	{
		%Target "@(Malterlib_Cloud_App_Targets)"
	}
}

Property
{
	MalterlibCloud_CloudClientExecutable "" // User(Cloud Debug)=/Deploy/Malterlib_Cloud/MalterlibCloud: Configure client executable to test local deploy to version manager
	{
		!!MalterlibCloud_CloudClientExecutable ""
	}
	MalterlibCloud_VersionUploadVersion "" // User(Cloud Debug): Allows you to override the version uploaded to version manager for debug purposes
	{
		!!MalterlibCloud_VersionUploadVersion ""
	}
	MalterlibCloud_VersionUploadForce "" // User(Cloud Debug)=true: Force uploads to version manager even if version already exists
	{
		!!MalterlibCloud_VersionUploadForce ""
	}
	MalterlibCloud_VersionUploadTags "" // User(Cloud Debug)=Debug: Set the tags to use when uploading to version managers
	{
		!!MalterlibCloud_VersionUploadTags ""
	}
	MalterlibCloud_VersionUploadHosts "@(MalterlibCloud_VersionUploadHostsDefault)" // User(Cloud Debug): Set the hosts to upload version to
	{
		!!MalterlibCloud_VersionUploadHosts ""
	}
	
	MalterlibCloud_VersionUploadSources "@(MalterlibBuildServerPutSources);@(MalterlibCloud_VersionUploadSources)"
	MalterlibCloud_VersionUploadSources "@(MalterlibCloudVersionInfoFileName)|/VersionInfo.json~;@(MalterlibCloud_VersionUploadSources)"
	{
		!MalterlibCloudVersionInfoFileName ""
	}

	MalterlibCloud_CloudClientCommand "\"@(MalterlibCloud_CloudClientExecutable)\""
	{
		!MalterlibCloud_CloudClientExecutable ""
	}
	MalterlibCloud_VersionUploadToolName "MalterlibCloud"
	{
		!!MalterlibCloud_VersionUploadToolName ""
	}
	MalterlibCloud_CloudClientCommand "MTool BuildServerTool Tool=@(MalterlibCloud_VersionUploadToolName)"
	{
		&
		{
			MalterlibBuildServerBuild true
			!MalterlibCloud_VersionUploadToolName ""
		}
	}
}

// Copy temp
Property
{
	MalterlibCloud_VersionUploadTempPath "@(Target.IntermediateDirectory)VersionUpload"
	
	MalterlibCloud_VersionUploadCopyTempTemplateRecursive 0
	MalterlibCloud_VersionUploadCopyTempTemplateRecursive 1
	{
		!"Expand0" "@(Expand0->Replace('^', ''))"
	}
 
	MalterlibCloud_VersionUploadCopyTempTemplateDirectory 0
	MalterlibCloud_VersionUploadCopyTempTemplateDirectory 1
	{
		!"Expand0" "@(Expand0->Replace('~', ''))"
	}

	MalterlibCloud_VersionUploadCopyTempTemplateDestinationFile 0
	MalterlibCloud_VersionUploadCopyTempTemplateDestinationFile 1
	{
		!"Expand1" "@(Expand1->Replace('~', ''))"
	}

	MalterlibCloud_VersionUploadCopyTempTemplateExpand	"MTool DiffCopy \"@(Expand0->ReplaceChars('~^', ''))\" \"@(MalterlibCloud_VersionUploadTempPath)@(MalterlibCloud_VersionUploadDestinationDir)@(Expand1->ReplaceChars('~^', ''))\" \"\" @(MalterlibCloud_VersionUploadCopyTempTemplateRecursive) 0 @(MalterlibCloud_VersionUploadCopyTempTemplateDirectory) @(MalterlibCloud_VersionUploadCopyTempTemplateDestinationFile)\r\n"\
														"@(CheckErrors)\r\n"

	MalterlibCloud_VersionUploadCopyTempTemplate	"@(Builtin.Function->ExpandList('@(Explodee)', '|', 'MalterlibCloud_VersionUploadCopyTempTemplateExpand'))"
	{
		!Explodee ""
	}
	
	MalterlibCloud_VersionUploadCopyTempContents	"@(Builtin.Function->ExplodeList('@(MalterlibCloud_VersionUploadSources)', ';', 'MalterlibCloud_VersionUploadCopyTempTemplate'))"
}

// Tags
Property
{
	MalterlibCloud_VersionUploadTagsTemplate	", \"@(Explodee)\""
	{
		&
		{
			!Explodee ""
			!GeneratorFamily VisualStudio
		}
	}
	MalterlibCloud_VersionUploadTagsTemplate	", \"^\"\"@(Explodee)\"^\"\""
	{
		&
		{
			!Explodee ""
			GeneratorFamily VisualStudio
		}
	}
	MalterlibCloud_VersionUploadTagsContents "$first@(Builtin.Function->ExplodeList('@(MalterlibCloud_VersionUploadTags)', ';', 'MalterlibCloud_VersionUploadTagsTemplate'))"
	{
		!MalterlibCloud_VersionUploadTags ""
	}
	MalterlibCloud_VersionUploadTagsContents "@(MalterlibCloud_VersionUploadTagsContents->Replace('$first, ', ''))"
}

// Upload
Property
{
	MalterlibCloud_VersionUploadCloudClientVersionSpecified " --version \"@(MalterlibCloud_VersionUploadVersion)\""
	{
		!MalterlibCloud_VersionUploadVersion ""
	}
	MalterlibCloud_VersionUploadCloudClientForceSpecified " --force"
	{
		!!MalterlibCloud_VersionUploadForce true
	}
	MalterlibCloud_VersionUploadCloudClientHostSpecified " --host \"@(Explodee)\""
	{
		!MalterlibCloud_VersionUploadHosts ""
	}
	
	MalterlibCloud_VersionUploadCloudClientCommand_Tags "'[@(MalterlibCloud_VersionUploadTagsContents)]'"
	{
		!GeneratorFamily VisualStudio
	}
	MalterlibCloud_VersionUploadCloudClientCommand_Tags "\"[@(MalterlibCloud_VersionUploadTagsContents)]\""
	{
		!!GeneratorFamily VisualStudio
	}
	
	MalterlibCloud_VersionUploadCloudClientCommand "@(MalterlibCloud_CloudClientCommand) --no-self-update-check --version-manager-upload-version --settings-file \"@(MalterlibCloudVersionInfoFileName)\" --tags @(MalterlibCloud_VersionUploadCloudClientCommand_Tags)@(MalterlibCloud_VersionUploadCloudClientVersionSpecified)@(MalterlibCloud_VersionUploadCloudClientForceSpecified)@(MalterlibCloud_VersionUploadCloudClientHostSpecified) \"@(MalterlibCloud_VersionUploadTarArchivePath)\"\r\n"\
													"@(CheckErrors)\r\n"
	{
		!!MalterlibCloud_VersionUploadToBuildServerPath ""
	}

	MalterlibCloud_VersionUploadCloudClientCommand 	"MTool BuildServerPut Recursive=0 \"Source=@(MalterlibCloud_VersionUploadTarArchivePath)\" \"DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)\"\r\n"\
													"@(CheckErrors)\r\n"\
													"MTool BuildServerPut Recursive=0 \"Source=@(MalterlibCloudVersionInfoFileName)\" \"DestinationDir=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)\"\r\n"\
													"@(CheckErrors)\r\n"
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath ""
			MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientCommand 	"MTool PostCopy \"@(MalterlibCloud_VersionUploadTarArchivePath)\" \"Config=@(MalterlibPostCopyConfigFile)\" \"Project=SimulateBuildServerStore\" \"OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)\"\r\n"\
													"@(CheckErrors)\r\n"\
													"MTool PostCopy \"@(MalterlibCloudVersionInfoFileName)\" \"Config=@(MalterlibPostCopyConfigFile)\" \"Project=SimulateBuildServerStore\" \"OutFolder=@(MalterlibCloud_VersionUploadToBuildServerPath)/@(MalterlibCloudPlatform)\"\r\n"\
													"@(CheckErrors)\r\n"
	{
		&
		{
			!MalterlibCloud_VersionUploadToBuildServerPath ""
			!MalterlibBuildServerBuild true
		}
	}

	MalterlibCloud_VersionUploadCloudClientTemplate	"@(MalterlibCloud_VersionUploadCloudClientCommand)"
	{
		!Explodee ""
	}
	
	MalterlibCloud_VersionUploadCloudClientContents "@(MalterlibCloud_VersionUploadCloudClientCommand)"
	{
		!!MalterlibCloud_VersionUploadHosts ""
	}
	
	MalterlibCloud_VersionUploadCloudClientContents "@(Builtin.Function->ExplodeList('@(MalterlibCloud_VersionUploadHosts)', ';', 'MalterlibCloud_VersionUploadCloudClientTemplate'))"
	{
		!MalterlibCloud_VersionUploadHosts ""
	}
}

Property
{
	MalterilbCloud_DoVersionManagerUpload true
	{
		&
		{
			MalterlibCloud_EnableVersionUpload true
			|
			{
				!MalterlibCloud_CloudClientExecutable ""
				&
				{
					MalterlibBuildServerBuild true
					!MalterlibCloud_VersionUploadToolName ""
				}
				!MalterlibCloud_VersionUploadToBuildServerPath ""
			}
			!MalterlibCloud_VersionUploadSources ""
			TargetIsExecutable true
			MalterlibCloudTarget true
		}
	}
	
	MalterlibBuildServerPutDisabled true
	{
		!!MalterilbCloud_DoVersionManagerUpload true
	}
	
	MalterlibCloud_VersionUploadTarArchivePath "@(Target.OutputDirectory)@(MalterlibCloudVersionInfo_Application).tar.gz"
	MalterlibCloud_VersionUploadTarArchivePathTar "@(MalterlibCloud_VersionUploadTarArchivePath)"
	MalterlibCloud_VersionUploadTarArchivePathTar "@(MalterlibCloud_VersionUploadTarArchivePath->ParseFormatString('{}:{}','/{0,cl}{1}'))"
	{
		!!PlatformFamily Windows // For MinGW
	}
	
	MalterlibPostBuildScript_Last "@(MalterlibPostBuildScript_Last)"\
					"[ -e \"@(MalterlibCloud_VersionUploadTempPath)\" ] && rm -rf \"@(MalterlibCloud_VersionUploadTempPath)\"\r\n"\
					"mkdir -p \"@(MalterlibCloud_VersionUploadTempPath)\"\r\n"\
					"@(MalterlibCloud_VersionUploadCopyTempContents)\r\n"\
					"pushd \"@(MalterlibCloud_VersionUploadTempPath)\" > /dev/null\r\n"\
					"@(CheckErrors)\r\n"\
					"tar @(TarOptions) -czf \"@(MalterlibCloud_VersionUploadTarArchivePathTar)\" .\r\n"\
					"@(CheckErrors)\r\n"\
					"popd > /dev/null\r\n"\
					"@(CheckErrors)\r\n"\
					"@(MalterlibCloud_VersionUploadCloudClientContents)\r\n"
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			!GeneratorFamily VisualStudio
		}
	}
	
	MalterlibPostBuildScript_Last "@(MalterlibPostBuildScript_Last)"\
					"IF EXIST \"@(MalterlibCloud_VersionUploadTempPath)\" rmdir /s /q \"@(MalterlibCloud_VersionUploadTempPath)\"\r\n"\
					"mkdir \"@(MalterlibCloud_VersionUploadTempPath)\"\r\n"\
					"@(MalterlibCloud_VersionUploadCopyTempContents)\r\n"\
					"pushd \"@(MalterlibCloud_VersionUploadTempPath)\"\r\n"\
					"@(CheckErrors)\r\n"\
					"pwd\"\r\n"\
					"tar @(TarOptions) -czf \"@(MalterlibCloud_VersionUploadTarArchivePathTar)\" .\r\n"\
					"@(CheckErrors)\r\n"\
					"popd\r\n"\
					"@(CheckErrors)\r\n"\
					"@(MalterlibCloud_VersionUploadCloudClientContents)\r\n"
	{
		&
		{
			MalterilbCloud_DoVersionManagerUpload true
			GeneratorFamily VisualStudio
		}
	}
	
}
