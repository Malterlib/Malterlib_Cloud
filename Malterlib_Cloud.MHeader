					MalterlibGenerateScheme: false
				}
				, Dependency.Link: false
				, Dependency.Stage: "Runtime"
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_Test"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_Test"
				, Dependency.TargetProperties: {
					MalterlibGenerateScheme: false
				}
				, Dependency.Link: false
				, Dependency.Stage: "Runtime"
			}
		}
		, {
			Name: "Com_Malterlib_Cloud_VersionManager"
			, Properties: {
				Dependency.Target: "Malterlib_Cloud_VersionManager"
